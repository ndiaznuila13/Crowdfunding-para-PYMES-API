generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int          @id @default(autoincrement())
  email       String       @unique
  password    String
  role        Role         @default(INVESTOR)
  balance     Float        @default(0.0)
  investments Investment[]
  projects    Project[]
}

model Project {
  id              Int          @id @default(autoincrement())
  title           String
  description     String
  fundingGoal     Float
  currentFunding  Float        @default(0.0)
  deadline        DateTime
  returnRate      Float
  status          Status       @default(DRAFT)
  ownerId         Int
  owner           User         @relation(fields: [ownerId], references: [id])
  investments     Investment[]
}

model Investment {
  id        Int      @id @default(autoincrement())
  amount    Float
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id])
}

enum Role {
  INVESTOR
  PYME
  ADMIN
}

enum Status {
  DRAFT
  ACTIVE
  FUNDED
  IN_PROGRESS
  COMPLETED
  DEFAULT
  CANCELED
}
